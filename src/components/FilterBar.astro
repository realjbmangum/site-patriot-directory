---
import type { Category } from '../lib/db';
import { STATE_MAP } from '../lib/utils';

interface Props {
  categories: Category[];
  states: { state: string; count: number }[];
  selectedCategory?: string;
  selectedState?: string;
}

const { categories, states, selectedCategory, selectedState } = Astro.props;
---

<form method="GET" class="bg-white rounded-lg shadow-sm border border-gray-100 p-4 mb-8">
  <div class="flex flex-col sm:flex-row gap-4">
    <!-- Category Filter -->
    <div class="flex-1">
      <label for="category" class="block text-sm font-medium text-navy mb-1">
        Category
      </label>
      <select
        name="category"
        id="category"
        class="w-full rounded-lg border-gray-300 shadow-sm text-sm focus:border-navy focus:ring-navy"
      >
        <option value="">All Categories</option>
        {categories.map((cat) => (
          <option value={cat.slug} selected={selectedCategory === cat.slug}>
            {cat.name} ({cat.count ?? 0})
          </option>
        ))}
      </select>
    </div>

    <!-- State Filter -->
    <div class="flex-1">
      <label for="state" class="block text-sm font-medium text-navy mb-1">
        State
      </label>
      <select
        name="state"
        id="state"
        class="w-full rounded-lg border-gray-300 shadow-sm text-sm focus:border-navy focus:ring-navy"
      >
        <option value="">All States</option>
        {states.map((s) => (
          <option value={s.state} selected={selectedState === s.state}>
            {STATE_MAP[s.state] || s.state} ({s.count})
          </option>
        ))}
      </select>
    </div>

    <!-- Submit -->
    <div class="flex items-end">
      <button
        type="submit"
        class="btn-primary text-sm px-5 py-2.5 w-full sm:w-auto"
      >
        Filter
      </button>
    </div>
  </div>
</form>
