---
import BusinessCard from './BusinessCard.astro';
import AdSlot from './AdSlot.astro';
import type { Business, Badge } from '../lib/db';

interface Props {
  businesses: Business[];
  badgesByBusiness?: Record<number, Badge[]>;
  title?: string;
}

const { businesses, badgesByBusiness = {}, title } = Astro.props;
---

<section>
  {title && (
    <h2 class="font-display text-2xl font-bold text-navy mb-6">{title}</h2>
  )}

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {businesses.map((business, index) => (
      <>
        <BusinessCard
          business={business}
          badges={badgesByBusiness[business.id] || []}
        />
        {/* Ad slot after every 8 cards */}
        {(index + 1) % 8 === 0 && (
          <div class="col-span-full">
            <AdSlot slot="in-feed" />
          </div>
        )}
      </>
    ))}
  </div>

  {businesses.length === 0 && (
    <div class="text-center py-12">
      <p class="text-gray-500 text-lg">No businesses found matching your filters.</p>
      <a href="/directory" class="btn-outline mt-4 inline-block">View all businesses</a>
    </div>
  )}
</section>
