---
const navLinks = [
  { href: '/directory', label: 'Browse' },
  { href: '/map', label: 'Map' },
  { href: '/about', label: 'About' },
];

const currentPath = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === '/directory') {
    return currentPath === '/directory' || currentPath.startsWith('/category/');
  }
  return currentPath.startsWith(href);
}
---

<header class="bg-white sticky top-0 z-50 shadow-lg border-b border-gray-100">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-32">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 group">
        <img src="/logo.png" alt="Patriot Directory" class="h-20 w-auto" />
        <span class="font-display text-xl font-bold tracking-tight text-navy group-hover:text-gold transition-colors">
          Patriot Directory
        </span>
      </a>

      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-8">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'text-sm font-medium transition-colors hover:text-gold',
              isActive(link.href) ? 'text-gold' : 'text-navy/70',
            ]}
          >
            {link.label}
          </a>
        ))}
        <a href="/submit" class="btn-primary text-sm px-4 py-2">
          Submit a Business
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 rounded-lg hover:bg-navy/10 transition-colors text-navy"
        aria-label="Open menu"
        aria-expanded="false"
      >
        <svg id="menu-icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="menu-icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Mobile Nav -->
    <div id="mobile-menu" class="hidden md:hidden pb-4">
      <div class="flex flex-col gap-2">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'px-3 py-2 rounded-lg text-sm font-medium transition-colors',
              isActive(link.href)
                ? 'bg-navy/10 text-gold'
                : 'text-navy/70 hover:bg-navy/10 hover:text-gold',
            ]}
          >
            {link.label}
          </a>
        ))}
        <a href="/submit" class="btn-primary text-sm px-4 py-2 text-center mt-1">
          Submit a Business
        </a>
      </div>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
