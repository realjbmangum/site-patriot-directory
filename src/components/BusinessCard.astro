---
import BadgePill from './BadgePill.astro';
import type { Business, Badge } from '../lib/db';
import { truncate, stateAbbrToSlug, slugify } from '../lib/utils';

interface Props {
  business: Business;
  badges?: Badge[];
}

const { business, badges = [] } = Astro.props;

const displayBadges = badges.slice(0, 3);
const extraBadgeCount = badges.length - 3;
const stateSlug = stateAbbrToSlug(business.state);
const citySlug = slugify(business.city);
---

<a
  href={`/business/${business.slug}`}
  class="card card-hover-accent group p-5 flex flex-col gap-3 hover:scale-[1.01] transition-all duration-200"
>
  <!-- Header -->
  <div class="flex items-start justify-between gap-2">
    <h3 class="font-display text-lg font-semibold text-navy group-hover:text-crimson transition-colors leading-tight">
      {business.name}
    </h3>
    {business.twitter_handle && (
      <span class="text-gray-400 flex-shrink-0" title={`@${business.twitter_handle}`}>
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
        </svg>
      </span>
    )}
  </div>

  <!-- Category & Location -->
  <div class="flex items-center gap-2 text-sm text-gray-500">
    <span class="font-medium text-navy/70">{business.category_name}</span>
    <span class="text-gray-300">|</span>
    <span>{business.city}, {business.state}</span>
  </div>

  <!-- Description -->
  {business.short_description && (
    <p class="text-sm text-gray-600 leading-relaxed">
      {truncate(business.short_description, 120)}
    </p>
  )}

  <!-- Badges -->
  {displayBadges.length > 0 && (
    <div class="flex flex-wrap gap-1.5 mt-auto pt-2">
      {displayBadges.map((badge) => (
        <BadgePill badge={badge} />
      ))}
      {extraBadgeCount > 0 && (
        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600">
          +{extraBadgeCount} more
        </span>
      )}
    </div>
  )}
</a>
