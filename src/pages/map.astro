---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getAllBusinessesForMap, getCategories } from '../lib/db';

const db = Astro.locals.runtime.env.DB;

const businesses = await getAllBusinessesForMap(db);
const categories = await getCategories(db);

// Get unique states for the state filter
const statesSet = new Set<string>();
for (const b of businesses) {
  statesSet.add(b.state);
}
const states = Array.from(statesSet).sort();

const pageTitle = 'Find Patriot Businesses Near You';
const pageDescription = `Interactive map of ${businesses.length}+ patriot businesses across America. Filter by category, search by city, or find businesses near you.`;
---

<BaseLayout title={pageTitle} description={pageDescription}>

  <!-- Mapbox CSS -->
  <link rel="stylesheet" href="https://api.mapbox.com/mapbox-gl-js/v3.3.0/mapbox-gl.css" slot="head" />
  <link rel="stylesheet" href="https://api.mapbox.com/mapbox-gl-js/plugins/mapbox-gl-geocoder/v5.0.2/mapbox-gl-geocoder.css" slot="head" />

  <div class="map-page flex flex-col" style="height: calc(100vh - 64px);">

    <!-- Filter Bar -->
    <div class="bg-navy px-4 py-3 flex-shrink-0">
      <div class="max-w-[1600px] mx-auto">
        <!-- Mobile: toggle button -->
        <button
          id="filter-toggle"
          class="lg:hidden flex items-center gap-2 text-white text-sm font-medium w-full"
          type="button"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" />
          </svg>
          Filters
          <svg id="filter-chevron" class="w-4 h-4 ml-auto transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>

        <!-- Filters (collapsible on mobile, always visible on desktop) -->
        <div id="filter-controls" class="hidden lg:flex flex-col lg:flex-row gap-3 mt-3 lg:mt-0 items-stretch lg:items-center">
          <!-- Category filter -->
          <div class="flex-1 max-w-xs">
            <select
              id="category-filter"
              class="w-full px-3 py-2 bg-white/10 text-white border border-white/20 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-gold appearance-none"
            >
              <option value="">All Categories</option>
              {categories.map((cat) => (
                <option value={String(cat.id)}>{cat.name}</option>
              ))}
            </select>
          </div>

          <!-- State filter -->
          <div class="flex-1 max-w-xs">
            <select
              id="state-filter"
              class="w-full px-3 py-2 bg-white/10 text-white border border-white/20 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-gold appearance-none"
            >
              <option value="">All States</option>
              {states.map((st) => (
                <option value={st}>{st}</option>
              ))}
            </select>
          </div>

          <!-- Geocoder will be inserted here -->
          <div id="geocoder-container" class="flex-1 max-w-xs"></div>
        </div>
      </div>
    </div>

    <!-- Main content: sidebar + map -->
    <div class="flex-1 flex flex-col lg:flex-row min-h-0">

      <!-- Sidebar (desktop: left 30%, mobile: below map) -->
      <div id="sidebar" class="order-2 lg:order-1 w-full lg:w-[30%] bg-white border-r border-gray-200 flex flex-col min-h-0 lg:max-h-full">
        <!-- Count -->
        <div class="px-4 py-3 border-b border-gray-200 bg-parchment flex-shrink-0">
          <p id="sidebar-count" class="text-sm font-medium text-navy">
            Showing <span id="filtered-count">{businesses.length}</span> of <span id="total-count">{businesses.length}</span> businesses
          </p>
        </div>

        <!-- List -->
        <div id="sidebar-list" class="flex-1 overflow-y-auto divide-y divide-gray-100" style="max-height: 50vh;">
        </div>
      </div>

      <!-- Map -->
      <div class="order-1 lg:order-2 flex-1 relative min-h-[50vh] lg:min-h-0">
        <div id="map" class="absolute inset-0"></div>
        <!-- Style switcher -->
        <div id="map-style-switcher" class="absolute top-2 left-2 z-10 flex rounded-md overflow-hidden shadow border border-gray-200 bg-white text-xs font-semibold">
          <button data-style="standard" class="style-btn px-3 py-1.5 text-navy bg-navy/10 border-r border-gray-200 hover:bg-gray-50 transition-colors">Map</button>
          <button data-style="satellite" class="style-btn px-3 py-1.5 text-gray-500 border-r border-gray-200 hover:bg-gray-50 transition-colors">Satellite</button>
          <button data-style="3d" class="style-btn px-3 py-1.5 text-gray-500 hover:bg-gray-50 transition-colors">3D</button>
        </div>
      </div>

    </div>
  </div>

  <!-- Business data for client-side JS -->
  <script id="businesses-data" type="application/json" set:html={JSON.stringify(businesses)} />
  <script id="categories-data" type="application/json" set:html={JSON.stringify(categories)} />

  <!-- Mapbox JS -->
  <script src="https://api.mapbox.com/mapbox-gl-js/v3.3.0/mapbox-gl.js" is:inline></script>
  <script src="https://api.mapbox.com/mapbox-gl-js/plugins/mapbox-gl-geocoder/v5.0.2/mapbox-gl-geocoder.min.js" is:inline></script>

  <script is:inline>
  (function() {
    // =========================================================================
    // DATA
    // =========================================================================
    const businesses = JSON.parse(document.getElementById('businesses-data').textContent);
    const categories = JSON.parse(document.getElementById('categories-data').textContent);
    const token = document.querySelector('meta[name="mapbox-token"]')?.content;

    if (!token) {
      console.error('Mapbox token not found');
      return;
    }

    mapboxgl.accessToken = token;

    // All businesses and currently filtered subset
    let allBusinesses = businesses;
    let filteredBusinesses = [...allBusinesses];
    let activePopup = null;

    // =========================================================================
    // FILTER TOGGLE (mobile)
    // =========================================================================
    const filterToggle = document.getElementById('filter-toggle');
    const filterControls = document.getElementById('filter-controls');
    const filterChevron = document.getElementById('filter-chevron');

    if (filterToggle) {
      filterToggle.addEventListener('click', () => {
        const isHidden = filterControls.classList.contains('hidden');
        if (isHidden) {
          filterControls.classList.remove('hidden');
          filterControls.classList.add('flex');
          filterChevron.style.transform = 'rotate(180deg)';
        } else {
          filterControls.classList.add('hidden');
          filterControls.classList.remove('flex');
          filterChevron.style.transform = '';
        }
      });
    }

    // =========================================================================
    // BUILD GEOJSON
    // =========================================================================
    function buildGeoJSON(data) {
      return {
        type: 'FeatureCollection',
        features: data
          .filter(b => b.latitude && b.longitude)
          .map(b => ({
            type: 'Feature',
            properties: {
              id: b.id,
              name: b.name,
              slug: b.slug,
              category_id: b.category_id,
              category_name: b.category_name,
              city: b.city,
              state: b.state,
              short_description: b.short_description || '',
            },
            geometry: {
              type: 'Point',
              coordinates: [b.longitude, b.latitude],
            },
          })),
      };
    }

    // =========================================================================
    // INITIALIZE MAP
    // =========================================================================
    const map = new mapboxgl.Map({
      container: 'map',
      style: 'mapbox://styles/mapbox/light-v11',
      center: [-98.5795, 39.8283], // Center of US
      zoom: 3.5,
      attributionControl: false,
    });

    // Controls
    map.addControl(new mapboxgl.NavigationControl(), 'top-right');
    map.addControl(
      new mapboxgl.GeolocateControl({
        positionOptions: { enableHighAccuracy: true },
        trackUserLocation: false,
        showUserHeading: false,
      }),
      'top-right'
    );
    map.addControl(new mapboxgl.FullscreenControl(), 'top-right');
    map.addControl(new mapboxgl.ScaleControl({ unit: 'imperial' }), 'bottom-left');

    // Geocoder
    const geocoder = new MapboxGeocoder({
      accessToken: mapboxgl.accessToken,
      mapboxgl: mapboxgl,
      countries: 'us',
      types: 'place,postcode',
      placeholder: 'Search city or zip...',
      marker: false,
    });

    const geocoderContainer = document.getElementById('geocoder-container');
    if (geocoderContainer) {
      geocoderContainer.appendChild(geocoder.onAdd(map));
    }

    // =========================================================================
    // MAP LAYERS — extracted so they can be re-added after a style switch
    // =========================================================================
    function setupLayers() {
      if (map.getSource('businesses')) return; // already added

      map.addSource('businesses', {
        type: 'geojson',
        data: buildGeoJSON(filteredBusinesses),
        cluster: true,
        clusterMaxZoom: 14,
        clusterRadius: 50,
      });

      map.addLayer({
        id: 'clusters',
        type: 'circle',
        source: 'businesses',
        filter: ['has', 'point_count'],
        paint: {
          'circle-color': '#1e2d4f',
          'circle-radius': ['step', ['get', 'point_count'], 18, 10, 24, 50, 32],
          'circle-stroke-width': 2,
          'circle-stroke-color': '#ffffff',
        },
      });

      map.addLayer({
        id: 'cluster-count',
        type: 'symbol',
        source: 'businesses',
        filter: ['has', 'point_count'],
        layout: {
          'text-field': ['get', 'point_count_abbreviated'],
          'text-font': ['DIN Offc Pro Medium', 'Arial Unicode MS Bold'],
          'text-size': 13,
        },
        paint: { 'text-color': '#ffffff' },
      });

      map.addLayer({
        id: 'unclustered-point',
        type: 'circle',
        source: 'businesses',
        filter: ['!', ['has', 'point_count']],
        paint: {
          'circle-color': '#c41e3a',
          'circle-radius': 8,
          'circle-stroke-width': 2,
          'circle-stroke-color': '#ffffff',
        },
      });
    }

    // Re-add layers after style switch (style.load fires before load on init)
    let layersReady = false;
    map.on('style.load', () => { if (layersReady) setupLayers(); });

    map.on('load', () => {
      layersReady = true;
      setupLayers();

      // Cluster click → zoom in
      map.on('click', 'clusters', (e) => {
        const features = map.queryRenderedFeatures(e.point, { layers: ['clusters'] });
        const clusterId = features[0].properties.cluster_id;
        map.getSource('businesses').getClusterExpansionZoom(clusterId, (err, zoom) => {
          if (err) return;
          map.easeTo({ center: features[0].geometry.coordinates, zoom });
        });
      });

      // Individual marker click → popup
      map.on('click', 'unclustered-point', (e) => {
        showPopup(e.features[0].geometry.coordinates.slice(), e.features[0].properties);
      });

      // Cursor styles
      map.on('mouseenter', 'clusters', () => { map.getCanvas().style.cursor = 'pointer'; });
      map.on('mouseleave', 'clusters', () => { map.getCanvas().style.cursor = ''; });
      map.on('mouseenter', 'unclustered-point', () => { map.getCanvas().style.cursor = 'pointer'; });
      map.on('mouseleave', 'unclustered-point', () => { map.getCanvas().style.cursor = ''; });

      map.fitBounds([[-125, 24], [-66, 50]], { padding: 40 });
      renderSidebar();
    });

    // =========================================================================
    // STYLE SWITCHER + 3D TERRAIN
    // =========================================================================
    const mapStyles = {
      standard: 'mapbox://styles/mapbox/light-v11',
      satellite: 'mapbox://styles/mapbox/satellite-streets-v12',
    };
    let is3D = false;

    function enableTerrain() {
      if (!map.getSource('mapbox-dem')) {
        map.addSource('mapbox-dem', {
          type: 'raster-dem',
          url: 'mapbox://mapbox.mapbox-terrain-dem-v1',
          tileSize: 512,
          maxzoom: 14,
        });
      }
      map.setTerrain({ source: 'mapbox-dem', exaggeration: 1.5 });

      if (!map.getLayer('3d-buildings')) {
        const layers = map.getStyle().layers;
        let firstLabelId;
        for (const layer of layers) {
          if (layer.type === 'symbol') { firstLabelId = layer.id; break; }
        }
        map.addLayer({
          id: '3d-buildings',
          source: 'composite',
          'source-layer': 'building',
          filter: ['==', 'extrude', 'true'],
          type: 'fill-extrusion',
          minzoom: 12,
          paint: {
            'fill-extrusion-color': '#aaa',
            'fill-extrusion-height': ['interpolate', ['linear'], ['zoom'], 15, 0, 15.05, ['get', 'height']],
            'fill-extrusion-base': ['interpolate', ['linear'], ['zoom'], 15, 0, 15.05, ['get', 'min_height']],
            'fill-extrusion-opacity': 0.6,
          },
        }, firstLabelId);
      }

      const zoom = map.getZoom();
      map.easeTo({ pitch: 45, bearing: -15, zoom: zoom < 12 ? 13 : zoom, duration: 800 });
      is3D = true;
    }

    function disableTerrain() {
      map.setTerrain(null);
      if (map.getLayer('3d-buildings')) map.removeLayer('3d-buildings');
      if (map.getSource('mapbox-dem')) map.removeSource('mapbox-dem');
      map.easeTo({ pitch: 0, bearing: 0, duration: 500 });
      is3D = false;
    }

    function setActiveStyleBtn(key) {
      document.querySelectorAll('.style-btn').forEach(btn => {
        const active = btn.dataset.style === key;
        btn.classList.toggle('text-navy', active);
        btn.classList.toggle('bg-navy/10', active);
        btn.classList.toggle('text-gray-500', !active);
        btn.classList.remove('bg-gray-50');
      });
    }

    function switchMapStyle(styleKey) {
      if (styleKey === '3d') {
        if (is3D) {
          disableTerrain();
          setActiveStyleBtn('standard');
        } else {
          enableTerrain();
          setActiveStyleBtn('3d');
        }
        return;
      }
      if (is3D) disableTerrain();
      map.setStyle(mapStyles[styleKey]); // style.load will re-add layers
      setActiveStyleBtn(styleKey);
    }

    document.querySelectorAll('.style-btn').forEach(btn => {
      btn.addEventListener('click', () => switchMapStyle(btn.dataset.style));
    });

    // =========================================================================
    // POPUP
    // =========================================================================
    function showPopup(coords, props) {
      if (activePopup) activePopup.remove();

      const desc = props.short_description
        ? (props.short_description.length > 80
            ? props.short_description.substring(0, 80).trimEnd() + '...'
            : props.short_description)
        : '';

      const html = `
        <div style="max-width: 250px; font-family: Inter, sans-serif;">
          <h3 style="margin: 0 0 4px; font-size: 15px; font-weight: 700; color: #1e2d4f;">${escapeHtml(props.name)}</h3>
          <p style="margin: 0 0 4px; font-size: 12px; color: #6b7280;">
            <span style="display: inline-block; padding: 1px 6px; background: #eef2ff; color: #1e2d4f; border-radius: 9999px; font-size: 11px; font-weight: 500;">${escapeHtml(props.category_name)}</span>
          </p>
          <p style="margin: 0 0 6px; font-size: 12px; color: #6b7280;">${escapeHtml(props.city)}, ${escapeHtml(props.state)}</p>
          ${desc ? `<p style="margin: 0 0 8px; font-size: 13px; color: #374151; line-height: 1.4;">${escapeHtml(desc)}</p>` : ''}
          <div style="display: flex; gap: 12px; align-items: center;">
            <a href="/business/${encodeURIComponent(props.slug)}" style="font-size: 13px; font-weight: 600; color: #c41e3a; text-decoration: none;">View Details &rarr;</a>
            <a href="https://www.google.com/maps?layer=c&cbll=${coords[1]},${coords[0]}" target="_blank" rel="noopener" style="font-size: 12px; color: #6b7280; text-decoration: none;">Street View</a>
          </div>
        </div>
      `;

      activePopup = new mapboxgl.Popup({ offset: 12, maxWidth: '280px' })
        .setLngLat(coords)
        .setHTML(html)
        .addTo(map);
    }

    function escapeHtml(str) {
      if (!str) return '';
      const div = document.createElement('div');
      div.textContent = str;
      return div.innerHTML;
    }

    // =========================================================================
    // SIDEBAR
    // =========================================================================
    function renderSidebar() {
      const list = document.getElementById('sidebar-list');
      const countEl = document.getElementById('filtered-count');

      countEl.textContent = filteredBusinesses.length;

      if (filteredBusinesses.length === 0) {
        list.innerHTML = '<div class="px-4 py-8 text-center text-gray-500 text-sm">No businesses match your filters.</div>';
        return;
      }

      let html = '';
      for (const b of filteredBusinesses) {
        html += `
          <div
            class="sidebar-item px-4 py-3 cursor-pointer hover:bg-parchment transition-colors"
            data-id="${b.id}"
            data-lng="${b.longitude}"
            data-lat="${b.latitude}"
            data-slug="${escapeHtml(b.slug)}"
          >
            <h4 class="text-sm font-semibold text-navy leading-tight">${escapeHtml(b.name)}</h4>
            <div class="flex items-center gap-2 mt-1">
              <span class="text-xs text-gray-500">${escapeHtml(b.category_name)}</span>
              <span class="text-gray-300 text-xs">|</span>
              <span class="text-xs text-gray-500">${escapeHtml(b.city)}, ${escapeHtml(b.state)}</span>
            </div>
          </div>
        `;
      }
      list.innerHTML = html;

      // Sidebar click handlers
      list.querySelectorAll('.sidebar-item').forEach(item => {
        item.addEventListener('click', () => {
          const lng = parseFloat(item.dataset.lng);
          const lat = parseFloat(item.dataset.lat);
          const id = parseInt(item.dataset.id);

          if (isNaN(lng) || isNaN(lat)) return;

          map.flyTo({ center: [lng, lat], zoom: 14 });

          // Find the business data and open popup
          const biz = filteredBusinesses.find(b => b.id === id);
          if (biz) {
            // Wait for flyTo to settle, then show popup
            setTimeout(() => {
              showPopup([lng, lat], {
                name: biz.name,
                slug: biz.slug,
                category_name: biz.category_name,
                city: biz.city,
                state: biz.state,
                short_description: biz.short_description || '',
              });
            }, 800);
          }
        });

        // Hover → highlight on map (visual feedback)
        item.addEventListener('mouseenter', () => {
          item.classList.add('bg-gold/10');
        });
        item.addEventListener('mouseleave', () => {
          item.classList.remove('bg-gold/10');
        });
      });
    }

    // =========================================================================
    // FILTERS
    // =========================================================================
    const categoryFilter = document.getElementById('category-filter');
    const stateFilter = document.getElementById('state-filter');

    function applyFilters() {
      const catVal = categoryFilter?.value || '';
      const stateVal = stateFilter?.value || '';

      filteredBusinesses = allBusinesses.filter(b => {
        if (catVal && String(b.category_id) !== catVal) return false;
        if (stateVal && b.state !== stateVal) return false;
        return true;
      });

      // Update map source
      if (map.getSource('businesses')) {
        map.getSource('businesses').setData(buildGeoJSON(filteredBusinesses));
      }

      // Update sidebar
      renderSidebar();

      // If filtering produced results, fit bounds to them
      if (filteredBusinesses.length > 0) {
        const coords = filteredBusinesses
          .filter(b => b.latitude && b.longitude)
          .map(b => [b.longitude, b.latitude]);

        if (coords.length === 1) {
          map.flyTo({ center: coords[0], zoom: 12 });
        } else if (coords.length > 1) {
          const bounds = coords.reduce(
            (bounds, coord) => bounds.extend(coord),
            new mapboxgl.LngLatBounds(coords[0], coords[0])
          );
          map.fitBounds(bounds, { padding: 60, maxZoom: 14 });
        }
      }
    }

    if (categoryFilter) categoryFilter.addEventListener('change', applyFilters);
    if (stateFilter) stateFilter.addEventListener('change', applyFilters);
  })();
  </script>

  <style is:inline>
    /* Override mapbox geocoder styles to match theme */
    .mapboxgl-ctrl-geocoder {
      min-width: 100% !important;
      width: 100% !important;
      max-width: 100% !important;
      box-shadow: none !important;
      border: 1px solid rgba(255,255,255,0.2) !important;
      background: rgba(255,255,255,0.1) !important;
      border-radius: 0.5rem !important;
      font-size: 14px !important;
    }
    .mapboxgl-ctrl-geocoder input {
      color: #ffffff !important;
    }
    .mapboxgl-ctrl-geocoder input::placeholder {
      color: rgba(255,255,255,0.5) !important;
    }
    .mapboxgl-ctrl-geocoder .mapboxgl-ctrl-geocoder--icon-search {
      fill: rgba(255,255,255,0.5) !important;
    }
    .mapboxgl-ctrl-geocoder .mapboxgl-ctrl-geocoder--button {
      background: transparent !important;
    }
    .mapboxgl-ctrl-geocoder .mapboxgl-ctrl-geocoder--icon-close {
      fill: rgba(255,255,255,0.5) !important;
    }
    .mapboxgl-ctrl-geocoder .suggestions {
      background: #ffffff !important;
      border-radius: 0.5rem !important;
      overflow: hidden !important;
    }
    .mapboxgl-ctrl-geocoder .suggestions > li > a {
      color: #1e2d4f !important;
    }
    .mapboxgl-ctrl-geocoder .suggestions > .active > a {
      background: #f8f7f4 !important;
    }

    /* Select styling for dark bg */
    #category-filter option,
    #state-filter option {
      background: #1e2d4f;
      color: #ffffff;
    }

    /* Sidebar scrollable area - desktop gets full height */
    @media (min-width: 1024px) {
      #sidebar-list {
        max-height: none !important;
      }
    }

    /* Map page specific: hide footer to get full viewport map */
    .map-page ~ footer {
      display: none;
    }

    /* Popup overrides */
    .mapboxgl-popup-content {
      padding: 14px !important;
      border-radius: 8px !important;
      box-shadow: 0 4px 20px rgba(0,0,0,0.15) !important;
    }
    .mapboxgl-popup-close-button {
      font-size: 18px !important;
      color: #6b7280 !important;
      right: 6px !important;
      top: 4px !important;
    }
  </style>

</BaseLayout>
