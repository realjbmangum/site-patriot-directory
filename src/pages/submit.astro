---
import BaseLayout from '../layouts/BaseLayout.astro';

const categories = [
  { slug: 'restaurants-food',    name: 'Restaurants & Food' },
  { slug: 'farms-agriculture',   name: 'Farms & Agriculture' },
  { slug: 'brewing-spirits',     name: 'Brewing & Spirits' },
  { slug: 'handmade-artisan',    name: 'Handmade & Artisan' },
  { slug: 'apparel-accessories', name: 'Apparel & Accessories' },
  { slug: 'firearms-outdoors',   name: 'Firearms & Outdoors' },
  { slug: 'home-building',       name: 'Home & Building' },
  { slug: 'faith-family',        name: 'Faith & Family' },
  { slug: 'health-wellness',     name: 'Health & Wellness' },
  { slug: 'services-trades',     name: 'Services & Trades' },
  { slug: 'books-media',         name: 'Books & Media' },
  { slug: 'pets-animals',        name: 'Pets & Animals' },
];
---

<BaseLayout
  title="Submit a Business — Patriot Directory"
  description="Know an American-owned business that belongs in the Patriot Directory? Submit it here."
>
  <section class="bg-navy text-white py-12">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="font-display text-3xl md:text-4xl font-bold mb-2">Submit a Business</h1>
      <p class="text-white/70">Know a patriot business that belongs here? Tell us about it.</p>
    </div>
  </section>

  <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

    <!-- Success state -->
    <div id="success-state" class="hidden bg-green-50 border border-green-200 rounded-lg p-8 text-center">
      <div class="text-4xl mb-4">🇺🇸</div>
      <h2 class="font-display text-2xl font-bold text-navy mb-2">Submission Received!</h2>
      <p class="text-gray-600 mb-6">Thanks for helping grow the directory. We'll review it and add it soon.</p>
      <a href="/directory" class="btn-primary">Browse the Directory</a>
    </div>

    <!-- Form -->
    <div id="form-container" class="bg-white rounded-lg shadow-sm border border-gray-100 p-6 md:p-8">

      <div id="error-msg" class="hidden mb-6 p-4 bg-red-50 border border-red-200 rounded-lg text-red-700 text-sm">
        Something went wrong. Please try again.
      </div>

      <form id="submit-form" action="https://api.web3forms.com/submit" method="POST" class="space-y-8">
        <input type="hidden" name="access_key" value="e820df72-1c50-44c3-94ef-4bf183b5aac8" />
        <input type="hidden" name="subject" value="New Patriot Business Submission" />
        <input type="hidden" name="from_name" value="Patriot Directory" />

        <!-- Business Info -->
        <div>
          <h2 class="font-display text-lg font-bold text-navy mb-4 pb-2 border-b border-gray-100">Business Info</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

            <div class="md:col-span-2">
              <label for="business_name" class="block text-sm font-medium text-navy mb-1">
                Business Name <span class="text-crimson">*</span>
              </label>
              <input
                type="text"
                id="business_name"
                name="business_name"
                required
                class="w-full rounded-lg border-gray-300 shadow-sm text-sm focus:border-navy focus:ring-navy"
                placeholder="e.g. Smith's Gun Shop"
              />
            </div>

            <div>
              <label for="website" class="block text-sm font-medium text-navy mb-1">Website</label>
              <input
                type="url"
                id="website"
                name="website"
                class="w-full rounded-lg border-gray-300 shadow-sm text-sm focus:border-navy focus:ring-navy"
                placeholder="https://example.com"
              />
            </div>

            <div>
              <label for="twitter_handle" class="block text-sm font-medium text-navy mb-1">X / Twitter Handle</label>
              <div class="relative">
                <span class="absolute inset-y-0 left-3 flex items-center text-gray-400 text-sm">@</span>
                <input
                  type="text"
                  id="twitter_handle"
                  name="twitter_handle"
                  class="w-full pl-7 rounded-lg border-gray-300 shadow-sm text-sm focus:border-navy focus:ring-navy"
                  placeholder="handle"
                />
              </div>
            </div>

            <div>
              <label for="category_slug" class="block text-sm font-medium text-navy mb-1">Category</label>
              <select
                id="category_slug"
                name="category_slug"
                class="w-full rounded-lg border-gray-300 shadow-sm text-sm focus:border-navy focus:ring-navy"
              >
                <option value="">Select a category...</option>
                {categories.map(cat => (
                  <option value={cat.slug}>{cat.name}</option>
                ))}
              </select>
            </div>

            <div class="grid grid-cols-2 gap-4 md:col-span-1">
              <div>
                <label for="city" class="block text-sm font-medium text-navy mb-1">City</label>
                <input
                  type="text"
                  id="city"
                  name="city"
                  class="w-full rounded-lg border-gray-300 shadow-sm text-sm focus:border-navy focus:ring-navy"
                  placeholder="Nashville"
                />
              </div>
              <div>
                <label for="state" class="block text-sm font-medium text-navy mb-1">State</label>
                <input
                  type="text"
                  id="state"
                  name="state"
                  maxlength={2}
                  class="w-full rounded-lg border-gray-300 shadow-sm text-sm focus:border-navy focus:ring-navy"
                  placeholder="TN"
                />
              </div>
            </div>

          </div>
        </div>

        <!-- Patriot Qualification -->
        <div>
          <h2 class="font-display text-lg font-bold text-navy mb-1 pb-2 border-b border-gray-100">Patriot Qualification</h2>
          <p class="text-xs text-gray-500 mb-4">This is what sets the Patriot Directory apart. Be specific.</p>

          <div class="space-y-6">

            <div>
              <label for="why_patriot" class="block text-sm font-medium text-navy mb-1">
                Why does this business deserve to be listed as a patriot company? <span class="text-crimson">*</span>
              </label>
              <textarea
                id="why_patriot"
                name="why_patriot"
                rows={4}
                required
                class="w-full rounded-lg border-gray-300 shadow-sm text-sm focus:border-navy focus:ring-navy"
                placeholder="Tell us what makes this business patriot-owned. Who are the owners, what do they stand for, what do they do that reflects American values?"
              ></textarea>
            </div>

            <div>
              <p class="block text-sm font-medium text-navy mb-3">Which of these apply? <span class="text-gray-400 font-normal">(check all that apply)</span></p>
              <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
                {[
                  { name: 'american_owned',   label: '🇺🇸 American-Owned' },
                  { name: 'veteran_owned',    label: '🎖️ Veteran-Owned' },
                  { name: 'family_owned',     label: '👨‍👩‍👧 Family-Owned' },
                  { name: 'made_in_usa',      label: '🏭 Made in USA' },
                  { name: 'christian_values', label: '✝️ Christian Values' },
                  { name: 'pro_2a',           label: '🔫 Pro-2A' },
                ].map(opt => (
                  <label class="flex items-center gap-2 p-3 rounded-lg border border-gray-200 cursor-pointer hover:border-navy hover:bg-cream transition-colors text-sm">
                    <input type="checkbox" name={opt.name} value="yes" class="rounded text-navy focus:ring-navy" />
                    <span>{opt.label}</span>
                  </label>
                ))}
              </div>
            </div>

            <div>
              <p class="block text-sm font-medium text-navy mb-3">Are you...</p>
              <div class="flex flex-col sm:flex-row gap-3">
                <label class="flex items-center gap-2 p-3 rounded-lg border border-gray-200 cursor-pointer hover:border-navy hover:bg-cream transition-colors text-sm flex-1">
                  <input type="radio" name="submitter_type" value="owner" class="text-navy focus:ring-navy" />
                  <span>The business owner</span>
                </label>
                <label class="flex items-center gap-2 p-3 rounded-lg border border-gray-200 cursor-pointer hover:border-navy hover:bg-cream transition-colors text-sm flex-1">
                  <input type="radio" name="submitter_type" value="nominator" class="text-navy focus:ring-navy" />
                  <span>Nominating someone else's business</span>
                </label>
              </div>
            </div>

          </div>
        </div>

        <!-- Contact Info -->
        <div>
          <h2 class="font-display text-lg font-bold text-navy mb-4 pb-2 border-b border-gray-100">Your Contact Info</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label for="contact_name" class="block text-sm font-medium text-navy mb-1">Your Name</label>
              <input
                type="text"
                id="contact_name"
                name="contact_name"
                class="w-full rounded-lg border-gray-300 shadow-sm text-sm focus:border-navy focus:ring-navy"
              />
            </div>
            <div>
              <label for="contact_email" class="block text-sm font-medium text-navy mb-1">
                Your Email <span class="text-crimson">*</span>
              </label>
              <input
                type="email"
                id="contact_email"
                name="contact_email"
                required
                class="w-full rounded-lg border-gray-300 shadow-sm text-sm focus:border-navy focus:ring-navy"
              />
            </div>
          </div>
        </div>

        <div class="flex items-center justify-between pt-2">
          <p class="text-xs text-gray-400"><span class="text-crimson">*</span> Required fields</p>
          <button type="submit" id="submit-btn" class="btn-primary px-8 py-3">
            Submit Business →
          </button>
        </div>

      </form>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('submit-form') as HTMLFormElement;
  const btn = document.getElementById('submit-btn') as HTMLButtonElement;
  const errorMsg = document.getElementById('error-msg') as HTMLDivElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.disabled = true;
    btn.textContent = 'Submitting...';
    errorMsg.classList.add('hidden');

    try {
      const response = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });

      if (response.ok) {
        document.getElementById('form-container')!.classList.add('hidden');
        document.getElementById('success-state')!.classList.remove('hidden');
        window.scrollTo({ top: 0, behavior: 'smooth' });
      } else {
        errorMsg.classList.remove('hidden');
        btn.disabled = false;
        btn.textContent = 'Submit Business →';
      }
    } catch {
      errorMsg.classList.remove('hidden');
      btn.disabled = false;
      btn.textContent = 'Submit Business →';
    }
  });
</script>
